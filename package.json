{
  "name": "markdown-it-mathematics",
  "version": "1.0.3",
  "description": "markdown-it mathematics plugin",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "default": "./dist/index.cjs",
        "types": "./dist/index.d.ts"
      },
      "import": {
        "default": "./dist/index.mjs",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "directories": {
    "test": "test",
    "lib": "dist"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky",
    "clean": "rimraf dist",
    "build": "rollup -c rollup.config.js && rollup -c rollup-all.config.js && tsc -b tsconfig.docs.json",
    "pack": "node packer.cjs --yarn",
    "prepack": "node prepack.cjs",
    "prepublish": "node prepack.cjs"
  },
  "keywords": [
    "markdown",
    "KaTeX",
    "math",
    "LaTeX",
    "markdown-it-plugin",
    "markdown-it"
  ],
  "author": {
    "email": "dimaslanjaka@gmail.com",
    "name": "dimaslanjaka",
    "url": "https://webmanajemen.com"
  },
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.3.5",
    "katex": "^0.16.46",
    "markdown-it": "https://github.com/dimaslanjaka/markdown-it/raw/17ccc825cbb3e4c6d59edada5f6d93f27075d752/release/markdown-it.tgz",
    "sbg-utility": "^2.0.11",
    "upath": "^3.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/babel__core": "^7",
    "@types/babel__preset-env": "^7",
    "@types/fs-extra": "^11.0.4",
    "@types/katex": "^0",
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "babel-jest": "^30.4.1",
    "binary-collections": "^2.0.10",
    "cross-spawn": "https://github.com/dimaslanjaka/node-cross-spawn/raw/80999ac7a7031a81e11ddb5fab0f8ba433041c98/release/cross-spawn.tgz",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jsonc-parser": "^3.3.1",
    "lint-staged": "^17.0.4",
    "markdown-it-testgen": "^0.1.6",
    "minimatch": "^10.2.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "cross-spawn": "https://github.com/dimaslanjaka/node-cross-spawn/raw/80999ac7a7031a81e11ddb5fab0f8ba433041c98/release/cross-spawn.tgz",
